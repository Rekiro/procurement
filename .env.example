# =============================================================================
# Smart ERP — Procurement Service — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
#
# Priority order (highest → lowest):
#   1. Real environment variables (shell / Docker / k8s Secret)
#   2. .env file in this directory
#   3. No .env + no env var → startup fails with a validation error
#
# Local dev : copy to .env, use the values below as-is
# Dev/Prod  : set real env vars in your deployment config
#             (docker-compose env_file, k8s Secret, systemd EnvironmentFile)
#             Do NOT commit .env to git.
# =============================================================================

# Application
APP_NAME=Smart ERP Procurement
DEBUG=true                  # false in dev/prod

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# Both commercial and procurement connect to the SAME database.
#
# Local : postgresql+psycopg://smarterp_dev:smarterp_dev@localhost:5432/smarterp
# Dev   : postgresql+psycopg://<user>:<pass>@<dev-db-host>:5432/smarterp
# Prod  : postgresql+psycopg://<user>:<pass>@<prod-db-host>:5432/smarterp
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://smarterp_dev:smarterp_dev@localhost:5432/smarterp

# ---------------------------------------------------------------------------
# JWT
# MUST match JWT_SECRET_KEY in the commercial app — tokens are shared.
# Generate a strong secret: openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---------------------------------------------------------------------------
# MinIO / S3 Object Storage
# Local : MinIO running via Docker (see docker-compose.yml)
# Dev/Prod: replace endpoint + credentials with your actual S3/MinIO config
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smarterp-procurement
MINIO_USE_SSL=false
